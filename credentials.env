# === EMAIL ===========================================================
EMAIL_DESTINATAIRE=olivierclery@hotmail.com

# Mode d'envoi : "ms365" (via connecteur Microsoft 365 dans Cowork)
#                ou "smtp" (fallback direct via le serveur Outlook)
EMAIL_MODE=smtp

# Si EMAIL_MODE=smtp, les 4 variables ci-dessous sont obligatoires.
# Compte 2FA actif → il faut un mot de passe d'application, PAS le
# mot de passe principal. Générer sur :
# https://account.microsoft.com/security → Options avancées → Mots de passe d'application
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=olivierclery@hotmail.com
SMTP_PASSWORD=

# === ADZUNA (API officielle, gratuit jusqu'à 250 appels/jour) ========
# À récupérer sur https://developer.adzuna.com (onglet "My API")
ADZUNA_APP_ID=eb57218d
ADZUNA_APP_KEY=
